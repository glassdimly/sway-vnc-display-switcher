#!/bin/bash
# sway-vnc-apply — regenerate ~/.config/sway/sway-vnc.conf from conf and reload sway
#
# Run this any time ~/.config/sway-vnc-display-switcher/conf changes to apply
# the new values to your live sway session without a full restart.
#
# What it does:
#   1. Sources conf via _lib.sh
#   2. Writes ~/.config/sway/sway-vnc.conf with workspace assignments,
#      keybindings, and exec_always lines derived from conf values
#   3. Calls swaymsg reload (exec_always re-runs kanshi-start and output-watcher)

set -u

# shellcheck source=_lib.sh
. "$(dirname "$(readlink -f "$0")")/_lib.sh"
svds_load_conf

OUT="${XDG_CONFIG_HOME:-$HOME/.config}/sway/sway-vnc.conf"
CONF_FILE="${XDG_CONFIG_HOME:-$HOME/.config}/sway-vnc-display-switcher/conf"

# Generate workspace assignment lines
WS_LINES=""
for i in $(seq 1 "$WS_MAX"); do
    WS_LINES+="workspace $i output $PHYSICAL_OUTPUT $HEADLESS_OUTPUT"$'\n'
done
# Parking workspace: always pinned to HEADLESS first so it doesn't pollute
# the user workspace range, but the real home is chosen at runtime by ws-migrate.
# We give it a name so sway never auto-assigns a numbered workspace to HDMI-A-1
# from the 1-WS_MAX range when in headless mode.
WS_LINES+="workspace 99 output $PHYSICAL_OUTPUT $HEADLESS_OUTPUT"$'\n'

# Write sway-vnc.conf
mkdir -p "$(dirname "$OUT")"
cat > "$OUT" << EOF
# ~/.config/sway/sway-vnc.conf
# Generated by sway-vnc-apply from $CONF_FILE.
# DO NOT edit directly — edit conf and run: sway-vnc-apply

# ── Workspace-to-output assignments ──────────────────────────────────────────
# Pin workspaces to physical output; headless is the fallback when it's absent.
${WS_LINES}
# ── Output migration keybindings ─────────────────────────────────────────────
# Manually move all workspaces to a target output (useful when kanshi misses a KVM switch).
bindsym ${KEY_MIGRATE_PHYSICAL} exec ws-migrate hdmi
bindsym ${KEY_MIGRATE_HEADLESS} exec ws-migrate headless

# ── Dropdown terminal ─────────────────────────────────────────────────────────
# Toggle quake-style scratchpad terminal
bindsym ${KEY_DROPDOWN} exec dropdown.sh
$([ -n "${KEY_DROPDOWN_2}" ] && echo "bindsym ${KEY_DROPDOWN_2} exec dropdown.sh")

# Launch dropdown terminal on startup (only if not already running)
exec_always swaymsg -t get_tree | grep -q '"app_id": "dropdown"' || ${TERMINAL} --class dropdown ${DROPDOWN_SHELL}

# Dropdown window rules: floating, top of screen, send to scratchpad
# no_focus prevents it stealing focus when created/reloaded — without this,
# keyboard input goes to the hidden scratchpad window and the session appears frozen.
no_focus [app_id="dropdown"]
for_window [app_id="dropdown"] {
    floating enable
    resize set width ${DROPDOWN_WIDTH} height ${DROPDOWN_HEIGHT}
    move position 0 0
    move scratchpad
}

# ── Kanshi + VNC autostart ────────────────────────────────────────────────────
exec_always bash -c 'f="\${XDG_RUNTIME_DIR:-/tmp}/kanshi-start.pid"; if [ -f "\$f" ]; then p=\$(cat "\$f"); kill "\$p" 2>/dev/null; for _ in \$(seq 1 30); do kill -0 "\$p" 2>/dev/null || break; sleep 0.01; done; fi; rm -f "\$f"; kanshi-start'
exec_always bash -c 'f="\${XDG_RUNTIME_DIR:-/tmp}/output-watcher.pgid"; if [ -f "\$f" ]; then p=\$(cat "\$f"); kill -9 -- -"\$p" 2>/dev/null; for _ in \$(seq 1 30); do kill -0 "\$p" 2>/dev/null || break; sleep 0.01; done; rm -f "\$f"; fi; output-watcher'
exec_always bash -c 'sleep 1.5; pgrep -x wayvnc || vnc-serve'
EOF

echo "Written: $OUT"

# Reload sway to apply changes
if command -v swaymsg >/dev/null 2>&1; then
    swaymsg reload && echo "sway reloaded"
else
    echo "swaymsg not found — reload sway manually"
fi
