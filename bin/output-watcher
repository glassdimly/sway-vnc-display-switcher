#!/bin/bash
# output-watcher — event-driven workspace migration on KVM/output state changes
#
# Two watchers run in parallel:
#
#  1. USB (primary, for EDID-preserving KVMs):
#     Watches udev USB kernel events for the KVM hub device.
#     KVM_USB_VID_PID in conf is the vendor:product ID (e.g. "05e3:0610").
#     The sysfs path is resolved dynamically at runtime.
#       remove → ws-migrate headless
#       add    → ws-migrate hdmi  (after 1.5s settle delay)
#
#  2. Sway output events (secondary, for EDID-dropping KVMs):
#     Queries get_outputs on each event; if PHYSICAL_OUTPUT active state
#     changes, migrates accordingly.
#
# Config: ~/.config/sway-vnc-display-switcher/conf
# Docs:   ~/.config/opencode/docs/remote-desktop.md

set -u

# ── Logging (must be set before _lib.sh for svds_log) ────────────────────────
_LOG_DIR="${XDG_STATE_HOME:-$HOME/.local/state}/sway-vnc"
_LOG_FILE="$_LOG_DIR/output-watcher.log"
mkdir -p "$_LOG_DIR"

# Re-exec under setsid so this script becomes a session/process-group leader.
# This means kill -- -$$ will reap ALL child processes (background subshells,
# udevadm pipes, swaymsg pipes) when the trap fires — no orphans on reload.
if [ "$$" != "$(ps -o pgid= -p $$ | tr -d ' ')" ]; then
    exec setsid "$0" "$@"
fi

# PID file stores our PGID so the exec_always restart wrapper can kill the
# entire process group without relying on pkill pattern-matching (which would
# accidentally match the wrapper bash itself and kill it before we start).
_PIDFILE="${XDG_RUNTIME_DIR:-/tmp}/output-watcher.pgid"
echo "$$" > "$_PIDFILE"

# shellcheck source=_lib.sh
. "$(dirname "$(readlink -f "$0")")/_lib.sh"
svds_load_conf
svds_rotate_logs
svds_resolve_usb_hub || true

# ── USB watcher (EDID-preserving KVMs) ───────────────────────────────────────
# Watches udev USB kernel events for add/remove of the KVM hub.
# Runs forever (udevadm doesn't exit on sway reload).
_usb_watcher() {
    # Re-resolve hub path each time the watcher (re)starts — handles USB
    # re-enumeration that changes bus-port assignments between restarts.
    svds_resolve_usb_hub || true
    [ -z "$KVM_USB_HUB" ] && { svds_log "USB: no hub found for VID_PID=${KVM_USB_VID_PID:-<none>} — skipping"; return; }

    local last_action=""

    udevadm monitor --kernel --subsystem-match=usb 2>/dev/null \
    | while IFS= read -r line; do
        [ -z "$line" ] && continue

        # Match lines like:
        #   KERNEL[...] remove   /devices/.../1-6/1-6.4 (usb)
        #   KERNEL[...] add      /devices/.../1-6/1-6.4 (usb)
        # Only the hub itself (path ends with /$KVM_USB_HUB), not its children.
        [[ "$line" =~ (add|remove)[[:space:]].*/${KVM_USB_HUB}[[:space:]] ]] || continue

        action="${BASH_REMATCH[1]}"
        [ "$action" = "$last_action" ] && continue
        last_action="$action"
        svds_log "USB: hub event detected: action=$action"

        if [ "$action" = "add" ]; then
            svds_log "USB: KVM hub added — migrating to hdmi (settling...)"
            # Hardware settle: USB hub re-enumeration + HDMI link training + EDID
            # + mode-set. Minimum 0.5s for physics (HDMI spec), then poll sway for
            # PHYSICAL_OUTPUT to become active. Max 3s — debounce layer catches misses.
            sleep 0.5
            for _settle in $(seq 1 10); do
                _state=$(_read_sway_state)
                [[ "$_state" = "1" ]] && break
                sleep 0.25
            done
            svds_log "USB: calling ws-migrate hdmi"
            ws-migrate hdmi 2>/dev/null || true
        else
            svds_log "USB: KVM hub removed — migrating to headless"
            svds_log "USB: calling ws-migrate headless"
            ws-migrate headless 2>/dev/null || true
        fi
    done
}

# ── Sway output watcher (EDID-dropping KVMs) ─────────────────────────────────
# NOTE: sway output events only carry {"change":"unspecified"} — no per-output
# fields. Query get_outputs on every event to detect actual state changes.
_read_sway_state() {
    PHYSICAL_OUTPUT="$PHYSICAL_OUTPUT" swaymsg -t get_outputs 2>/dev/null | python3 -c "
import json, sys, os
try:
    for o in json.load(sys.stdin):
        if o['name'] == os.environ['PHYSICAL_OUTPUT']:
            print('1' if o.get('active', False) else '0')
            sys.exit(0)
except Exception:
    pass
print('0')
"
}

_sway_watcher() {
    local last_active=""
    last_active=$(_read_sway_state)  # snapshot state before the subscribe loop starts

    swaymsg -t subscribe '["output"]' 2>/dev/null | while IFS= read -r line; do
        [ -z "$line" ] && continue

        active=$(_read_sway_state)
        [ "$active" = "$last_active" ] && continue  # no change, nothing to do

        # Potential state change detected — debounce before acting.
        #
        # Problem: ws-migrate calls swaymsg output commands that cause sway to
        # return active=False for PHYSICAL_OUTPUT transiently during reconfiguration
        # (~50-200ms). Without debounce, the watcher would see "1→0", call
        # ws-migrate in the opposite direction, and the two concurrent calls would
        # race on output position commands — leaving both outputs at 0,0 (overlapping).
        #
        # Fix: wait 2s (> ws-migrate's full runtime of ~1.5s) then re-read. If the
        # state change was transient it will have resolved; a real disconnect won't.
        # Debounce: ws-migrate fires swaymsg output commands that cause transient
        # active=False on PHYSICAL_OUTPUT (~50-200ms). Wait longer than ws-migrate's
        # full runtime (~1s with IPC sync barriers) to filter transient state changes.
        # Re-read after debounce to confirm real change.
        sleep 1.5
        active=$(_read_sway_state)
        [ "$active" = "$last_active" ] && continue  # was transient — ignore

        # Confirmed real state change. Update last_active before migrating so that
        # output events fired *during* the migration don't re-enter this branch.
        last_active="$active"
        svds_log "SWAY: output state changed: active=$active"

        if [ "$active" = "1" ]; then
            svds_log "SWAY: PHYSICAL_OUTPUT connected — migrating to hdmi (settling...)"
            # Hardware settle: HDMI reconnect needs EDID negotiation + mode-set.
            # Minimum 0.5s, then poll for output to stabilize.
            sleep 0.5
            for _settle in $(seq 1 10); do
                _state=$(_read_sway_state)
                [[ "$_state" = "1" ]] && break
                sleep 0.25
            done
            svds_log "SWAY: calling ws-migrate hdmi"
            ws-migrate hdmi 2>/dev/null || true
        else
            svds_log "SWAY: PHYSICAL_OUTPUT disconnected — migrating to headless"
            ws-migrate headless 2>/dev/null || true
        fi

        # Re-sync last_active to the actual post-migration compositor state.
        # ws-migrate may have left the output in a different active value than
        # the one that triggered this branch (e.g. if it was skipped via flock).
        # Without this re-sync, the next output event would see a false delta
        # and fire another spurious migration.
        last_active=$(_read_sway_state)
    done
}

# ── Startup state check ──────────────────────────────────────────────────────
# udevadm monitor only catches future events; it misses whatever already
# happened before this process started (e.g. sway reload while KVM was already
# switched away). Check the current USB hub presence and migrate immediately.
_startup_check() {
    # Re-resolve hub path — may have changed since last boot/reload
    svds_resolve_usb_hub || true
    [ -z "$KVM_USB_HUB" ] && { svds_log "STARTUP: no hub found for VID_PID=${KVM_USB_VID_PID:-<none>} — skipping KVM check"; return; }

    # Wait for BOTH sway IPC readiness AND the headless output to exist.
    # vnc-serve creates HEADLESS-1 asynchronously; without it, ws-migrate has
    # nowhere to park ws 99 and the migration is a no-op. Poll up to 15s.
    local _headless_ready=0
    for _ready in $(seq 1 30); do
        svds_get_headless
        if [ -n "$HEADLESS_OUTPUT" ]; then
            _headless_ready=1
            break
        fi
        sleep 0.5
    done

    if [ "$_headless_ready" = "0" ]; then
        svds_log "STARTUP: timed out waiting for headless output (15s) — skipping migration"
        return
    fi

    svds_log "STARTUP: headless output ready ($HEADLESS_OUTPUT)"

    if [ -e "/sys/bus/usb/devices/${KVM_USB_HUB}" ]; then
        svds_log "STARTUP: KVM hub present — migrating to hdmi"
        ws-migrate hdmi 2>/dev/null || true
    else
        svds_log "STARTUP: KVM hub absent — migrating to headless"
        ws-migrate headless 2>/dev/null || true
    fi
}

# ── Main ─────────────────────────────────────────────────────────────────────
# Kill entire process group on exit — catches all background subshells,
# udevadm/swaymsg pipes, and any nested children. No orphans on sway reload.
trap 'rm -f "$_PIDFILE"; kill -9 -- -$$ 2>/dev/null; exit' EXIT INT TERM

svds_log "output-watcher started (PID=$$, PHYSICAL=$PHYSICAL_OUTPUT, HEADLESS=$HEADLESS_OUTPUT, KVM_VID_PID=${KVM_USB_VID_PID:-<none>}, KVM_HUB=${KVM_USB_HUB:-<none>})"

# Startup state check: background so watchers start immediately in parallel
_startup_check &

# USB watcher: background, loops forever (needs either a resolved hub or vid_pid to resolve later)
if [ -n "$KVM_USB_HUB" ] || [ -n "${KVM_USB_VID_PID:-}" ]; then
    while true; do
        _usb_watcher
        sleep 1  # restart backoff: prevent spin-loop if udevadm exits immediately
        svds_log "USB: watcher restarted"
    done &
fi

# Sway output watcher: foreground, restarts on sway reload
_sway_backoff=1
while true; do
    _sway_start=$SECONDS
    _sway_watcher
    # If it ran for more than 5s, the connection was real — reset backoff
    (( SECONDS - _sway_start > 5 )) && _sway_backoff=1
    sleep "$_sway_backoff"
    svds_log "SWAY: watcher restarted (backoff=${_sway_backoff}s)"
    (( _sway_backoff = _sway_backoff < 10 ? _sway_backoff * 2 : 10 ))
done
