#!/bin/bash
# output-watcher — event-driven workspace migration on KVM/output state changes
#
# Two watchers run in parallel:
#
#  1. USB (primary, for EDID-preserving KVMs):
#     Watches udev USB kernel events for the KVM hub device.
#     KVM_USB_VID_PID in conf is the vendor:product ID (e.g. "05e3:0610").
#     The sysfs path is resolved dynamically at runtime.
#       remove → ws-migrate headless
#       add    → ws-migrate hdmi  (after 0.5s hardware settle)
#
#  2. Sway output events (secondary, for EDID-dropping KVMs + startup):
#     Handles two cases:
#       A. Headless output appears  → check KVM hub → migrate (replaces startup check)
#       B. PHYSICAL_OUTPUT active state changes → debounce + migrate
#
# No polling. No _startup_check(). Boot sequence:
#   sway starts → output-watcher subscribes to output events → vnc-serve creates
#   HEADLESS-1 → sway fires output event → watcher reacts with correct migration.
#
# Config: ~/.config/sway-vnc-display-switcher/conf

set -u

# ── Logging ───────────────────────────────────────────────────────────────────
_LOG_DIR="${XDG_STATE_HOME:-$HOME/.local/state}/sway-vnc"
_LOG_FILE="$_LOG_DIR/output-watcher.log"
mkdir -p "$_LOG_DIR"

# Re-exec under setsid so this script is a session/process-group leader.
# kill -- -$$ then reaps ALL child processes cleanly.
if [ "$$" != "$(ps -o pgid= -p $$ | tr -d ' ')" ]; then
    exec setsid "$0" "$@"
fi

_PIDFILE="${XDG_RUNTIME_DIR:-/tmp}/output-watcher.pgid"
echo "$$" > "$_PIDFILE"

# shellcheck source=_lib.sh
. "$(dirname "$(readlink -f "$0")")/_lib.sh"
svds_load_conf
svds_rotate_logs
svds_resolve_usb_hub || true

# ── Cross-watcher dedup ───────────────────────────────────────────────────────
# Prevent both USB and sway watchers from firing redundant ws-migrate calls
# for the same KVM switch. Stored in a temp file so subshells can read it.
_DEDUP_FILE="${XDG_RUNTIME_DIR:-/tmp}/output-watcher-last-migrate"

_dedup_check() {
    # Usage: _dedup_check <direction>
    # Returns 0 (ok to migrate) or 1 (skip — same direction within 3s)
    local dir="$1"
    if [ -f "$_DEDUP_FILE" ]; then
        local last_dir last_time
        last_dir=$(cut -d: -f1 "$_DEDUP_FILE" 2>/dev/null)
        last_time=$(cut -d: -f2 "$_DEDUP_FILE" 2>/dev/null)
        if [ "$last_dir" = "$dir" ] && (( SECONDS - ${last_time:-0} < 3 )); then
            return 1
        fi
    fi
    return 0
}

_dedup_record() {
    echo "${1}:${SECONDS}" > "$_DEDUP_FILE"
}

_migrate() {
    local dir="$1" reason="$2"
    if ! _dedup_check "$dir"; then
        svds_log "${reason}: skipping ws-migrate $dir (dedup — same direction within 3s)"
        return
    fi
    _dedup_record "$dir"
    svds_log "${reason}: calling ws-migrate $dir"
    ws-migrate "$dir" 2>/dev/null || true
}

# ── USB watcher (EDID-preserving KVMs) ───────────────────────────────────────
_usb_watcher() {
    svds_resolve_usb_hub || true
    [ -z "$KVM_USB_HUB" ] && {
        svds_log "USB: no hub found for VID_PID=${KVM_USB_VID_PID:-<none>} — skipping"
        return
    }

    local last_action=""

    udevadm monitor --kernel --subsystem-match=usb 2>/dev/null \
    | while IFS= read -r line; do
        [ -z "$line" ] && continue
        [[ "$line" =~ (add|remove)[[:space:]].*/${KVM_USB_HUB}[[:space:]] ]] || continue

        action="${BASH_REMATCH[1]}"
        [ "$action" = "$last_action" ] && continue
        last_action="$action"
        svds_log "USB: hub event: action=$action"

        if [ "$action" = "add" ]; then
            # Hardware settle: USB enumeration + HDMI EDID + mode-set.
            # EDID-preserving KVM: _read_sway_state always returns 1, no need to poll.
            sleep 0.5
            _migrate hdmi "USB"
        else
            _migrate headless "USB"
        fi
    done
}

# ── Sway output watcher ───────────────────────────────────────────────────────
_read_sway_state() {
    PHYSICAL_OUTPUT="$PHYSICAL_OUTPUT" swaymsg -t get_outputs 2>/dev/null | python3 -c "
import json, sys, os
try:
    for o in json.load(sys.stdin):
        if o['name'] == os.environ['PHYSICAL_OUTPUT']:
            print('1' if o.get('active', False) else '0')
            sys.exit(0)
except Exception:
    pass
print('0')
"
}

_handle_headless_appeared() {
    svds_get_headless
    [ -z "$HEADLESS_OUTPUT" ] && return

    # Idempotency check: if workspaces are already correctly placed, skip.
    # "Correctly placed" means all 1..WS_MAX workspaces are on the target output.
    local target_dir target_output wrong_count
    if [ -n "$KVM_USB_HUB" ] && [ -e "/sys/bus/usb/devices/${KVM_USB_HUB}" ]; then
        target_dir="hdmi"
        target_output="$PHYSICAL_OUTPUT"
    else
        target_dir="headless"
        target_output="$HEADLESS_OUTPUT"
    fi

    wrong_count=$(swaymsg -t get_workspaces 2>/dev/null | \
        TARGET="$target_output" WS_MAX="$WS_MAX" python3 -c "
import json, sys, os
ws = json.load(sys.stdin)
target = os.environ['TARGET']
ws_max = int(os.environ['WS_MAX'])
wrong = [w for w in ws if 1 <= w.get('num', -1) <= ws_max and w.get('output') != target]
print(len(wrong))
" 2>/dev/null)

    if [ "${wrong_count:-1}" = "0" ]; then
        svds_log "SWAY: headless appeared — workspaces already on $target_output, skipping migration"
        return
    fi

    _migrate "$target_dir" "SWAY(headless-appeared)"
}

_sway_watcher() {
    # Wait for sway IPC socket — eliminates restart spam during boot
    while [ ! -S "${SWAYSOCK:-/dev/null}" ]; do sleep 0.5; done

    # Init: check current output state before subscribing.
    # Handles two cases:
    #   1. Cold boot: headless doesn't exist yet → subscribe and wait for it to appear
    #   2. Sway reload / output-watcher restart: headless already exists → handle now
    local headless_seen=0
    local last_active
    last_active=$(_read_sway_state)

    svds_get_headless
    if [ -n "$HEADLESS_OUTPUT" ]; then
        headless_seen=1
        _handle_headless_appeared
    fi

    swaymsg -t subscribe '["output"]' 2>/dev/null | while IFS= read -r line; do
        [ -z "$line" ] && continue

        # Case A: headless output appeared for the first time this session
        if [ "$headless_seen" = "0" ]; then
            svds_get_headless
            if [ -n "$HEADLESS_OUTPUT" ]; then
                headless_seen=1
                svds_log "SWAY: headless output appeared ($HEADLESS_OUTPUT)"
                _handle_headless_appeared
                last_active=$(_read_sway_state)
                continue
            fi
        fi

        # Case B: PHYSICAL_OUTPUT active state changed (EDID-dropping KVMs)
        active=$(_read_sway_state)
        [ "$active" = "$last_active" ] && continue

        # Debounce: ws-migrate fires swaymsg output commands that cause transient
        # active=False on PHYSICAL_OUTPUT (~50-200ms). Wait > ws-migrate runtime
        # (~1s) before acting to filter transient state changes.
        sleep 1.5
        active=$(_read_sway_state)
        [ "$active" = "$last_active" ] && continue

        last_active="$active"
        svds_log "SWAY: output state changed: active=$active"

        if [ "$active" = "1" ]; then
            sleep 0.5  # HDMI link training settle
            _migrate hdmi "SWAY"
        else
            _migrate headless "SWAY"
        fi

        last_active=$(_read_sway_state)
    done
}

# ── Main ──────────────────────────────────────────────────────────────────────
trap 'rm -f "$_PIDFILE" "$_DEDUP_FILE"; kill -9 -- -$$ 2>/dev/null; exit' EXIT INT TERM

svds_log "output-watcher started (PID=$$, PHYSICAL=$PHYSICAL_OUTPUT, HEADLESS=$HEADLESS_OUTPUT, KVM_VID_PID=${KVM_USB_VID_PID:-<none>}, KVM_HUB=${KVM_USB_HUB:-<none>})"

# USB watcher: background, loops forever
if [ -n "$KVM_USB_HUB" ] || [ -n "${KVM_USB_VID_PID:-}" ]; then
    while true; do
        _usb_watcher
        sleep 1
        svds_log "USB: watcher restarted"
    done &
fi

# Sway output watcher: foreground, restarts with exponential backoff
_sway_backoff=1
while true; do
    _sway_start=$SECONDS
    _sway_watcher
    # Reset backoff if the watcher ran for a meaningful time (was connected)
    (( SECONDS - _sway_start > 5 )) && _sway_backoff=1
    sleep "$_sway_backoff"
    svds_log "SWAY: watcher restarted (backoff=${_sway_backoff}s)"
    (( _sway_backoff = _sway_backoff < 10 ? _sway_backoff * 2 : 10 ))
done
